# Required: Supabase Project Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Required: public Vercel deployment URL (no trailing slash)
PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app
ALLOWED_ORIGINS=https://YOUR_PROJECT.vercel.app
ALLOWED_PAYMENT_REDIRECT_ORIGINS=https://YOUR_PROJECT.vercel.app

# Required for the live AI engine unless keys are stored from the admin portal
DECART_API_KEY=REPLACE_ME

# Required for Flutterwave card/bank checkout
FLUTTERWAVE_SECRET_KEY=FLWSECK_REPLACE_ME
FLUTTERWAVE_WEBHOOK_HASH=REPLACE_WITH_A_LONG_RANDOM_VALUE

# Required for NOWPayments crypto checkout
NOWPAYMENTS_API_KEY=REPLACE_ME
NOWPAYMENTS_IPN_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_VALUE
NOWPAYMENTS_PAY_CURRENCY=USDTTRC20

# Recommended: enables privacy-preserving referral fraud checks
REFERRAL_HASH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES

# Optional: only required for the admin mass-email button
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=Morphly <no-reply@YOUR_VERIFIED_DOMAIN.com>
