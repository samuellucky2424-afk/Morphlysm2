<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/streamMiniRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_stream_mini_window"
    android:elevation="10dp"
    android:gravity="center_vertical"
    android:minWidth="184dp"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/streamMiniCollapsed"
        android:layout_width="184dp"
        android:layout_height="184dp">

        <ImageView
            android:id="@+id/ivStreamMiniPreviewCollapsed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#05070C"
            android:contentDescription="Live output preview"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_stream_mini_pulse" />

        <TextView
            android:id="@+id/tvStreamMiniElapsed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#99000000"
            android:gravity="center"
            android:paddingVertical="5dp"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/streamMiniExpanded"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="7dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStreamMiniTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIVE OUTPUT PREVIEW"
            android:textColor="#FFF0C243"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivStreamMiniPreviewExpanded"
            android:layout_width="match_parent"
            android:layout_height="156dp"
            android:layout_marginTop="5dp"
            android:background="#05070C"
            android:contentDescription="Live output preview"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvStreamMiniStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Live session is active"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvStreamMiniSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Session: --"
            android:textColor="#888D9B"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStreamMiniOpenApps"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#FFF0C243"
                android:text="CLONED APPS"
                android:textColor="#0B0C10"
                android:textSize="9sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStreamMiniStop"
                android:layout_width="68dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_stream_stop_button"
                android:text="STOP"
                android:textColor="#0B0C10"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
