{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin.js?path=:path*"
    },
    {
      "source": "/api/credits/:path*",
      "destination": "/api/credits.js?path=:path*"
    },
    {
      "source": "/api/decart-token",
      "destination": "/api/config.js?route=decart-token"
    },
    {
      "source": "/api/transform",
      "destination": "/api/config.js?route=transform"
    }
  ],
  "functions": {
    "api/admin.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
